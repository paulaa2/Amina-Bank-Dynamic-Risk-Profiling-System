# Local inference
OLLAMA_HOST=http://localhost:11434
OLLAMA_EXTRACTOR_MODEL=qwen3:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Optional cloud report generation
# Leave empty to use deterministic fallback reports.
GROQ_API_KEY=
GROQ_REPORT_MODEL=llama-3.3-70b-versatile

# Runtime configuration
DATABASE_URL=sqlite:///data/risk_profiling.db
TARGET_FWER=0.05
COMBINED_RISK_THRESHOLD=0.5
MAX_EVENTS_PER_RUN=6
USE_LLM_BURN_IN=false
SIMULATE_TX_ANOMALY=false

# Optional data collection
FIRECRAWL_API_KEY=
